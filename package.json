{
  "name": "creami-recipes",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build && node scripts/postbuild-locale-routes.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "a11y": "npx axe http://localhost:4321/ http://localhost:4321/recipes http://localhost:4321/about --exit",
    "a11y:pa11y": "npx pa11y --standard WCAG2AA http://localhost:4321/",
    "seed": "tsx scripts/seed-recipes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vercel": "^10.0.2",
    "@gsap/react": "^2.1.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "gsap": "^3.14.2",
    "marked": "^17.0.5",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@axe-core/cli": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "pa11y": "^9.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
