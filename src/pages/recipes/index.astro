---
export const prerender = false;

import BaseLayout from '../../components/layout/BaseLayout.astro';
import RecipeFilters from '../../components/recipe/RecipeFilters';
import AdUnit from '../../components/ads/AdUnit.astro';
import { supabase } from '../../lib/supabase';
import { getFilteredRecipes, getCategories, getCreamiModels } from '../../lib/recipes';
import type { RecipeQueryParams } from '../../lib/recipes';
import { t } from '../../i18n';
import { ui } from '../../lib/translations';

const locale = Astro.locals.locale;
const url = Astro.url;

// Read URL params so the server-rendered page matches the user's filter state
const initialParams: RecipeQueryParams = {
  q: url.searchParams.get('q') || undefined,
  base: url.searchParams.getAll('base').filter(Boolean),
  difficulty: url.searchParams.getAll('difficulty').filter(Boolean),
  flavor: url.searchParams.getAll('flavor').filter(Boolean),
  dietary: url.searchParams.getAll('dietary').filter(Boolean),
  tag: url.searchParams.getAll('tag').filter(Boolean),
  model: url.searchParams.getAll('model').filter(Boolean),
  rating: url.searchParams.get('rating') ? Number(url.searchParams.get('rating')) : undefined,
  sort: (url.searchParams.get('sort') as RecipeQueryParams['sort']) || 'newest',
  page: 1,
  pageSize: 24,
  locale,
};

const { recipes: initialRecipes, total, facets } = await getFilteredRecipes(supabase, initialParams);

const [categories, models] = await Promise.all([
  getCategories(supabase),
  getCreamiModels(supabase),
]);

const filterConfig = {
  baseTypes: categories.filter((c) => c.type === 'base_type').map((c) => ({ slug: c.slug, name: ui(c.name, locale) })),
  flavorProfiles: categories.filter((c) => c.type === 'flavor_profile').map((c) => ({ slug: c.slug, name: ui(c.name, locale) })),
  dietary: categories.filter((c) => c.type === 'dietary').map((c) => ({ slug: c.slug, name: ui(c.name, locale) })),
  models: models.map((m) => ({ slug: m.slug, name: m.name })),
};

const filterLabels = {
  searchPlaceholder: t('nav.searchPlaceholder', locale),
  sortNewest: t('recipes.sortNewest', locale),
  sortRating: t('recipes.sortRating', locale),
  sortReviews: t('recipes.sortReviews', locale),
  sortPrep: t('recipes.sortPrep', locale),
  filters: t('recipes.filters', locale),
  quickFilters: t('recipes.quickFilters', locale),
  difficulty: t('recipes.difficulty', locale),
  baseType: t('recipes.baseType', locale),
  dietary: t('recipes.dietary', locale),
  minRating: t('recipes.minRating', locale),
  showing: t('recipes.showing', locale),
  recipe: t('recipes.recipe', locale),
  recipes: t('recipes.recipePlural', locale),
  clearAll: t('recipes.clearAll', locale),
  noResults: t('recipes.noResults', locale),
  noResultsDesc: t('recipes.noResultsDesc', locale),
  clearFilters: t('recipes.clearFilters', locale),
  loadMore: t('home.viewAll', locale),
  of: t('recipes.of', locale),
  stars: t('recipes.stars', locale),
  prep: ui('prep', locale).toLowerCase(),
  easyBeginner: t('recipes.beginner', locale),
  highProtein: ui('High Protein', locale),
  vegan: ui('Vegan', locale),
  ketoFriendly: ui('Keto', locale),
  dairyFree: ui('Dairy-Free', locale),
  softServe: ui('Soft Serve', locale),
  beginner: ui('beginner', locale),
  intermediate: ui('intermediate', locale),
  advanced: ui('advanced', locale),
  baseTypeMap: Object.fromEntries(
    ['Ice Cream', 'Sorbet', 'Gelato', 'Frozen Yogurt', 'Milkshake', 'Smoothie Bowl', 'Lite Ice Cream', 'Italian Ice']
      .map(bt => [bt, ui(bt, locale)])
  ),
  loading: t('common.loading', locale),
};
---

<BaseLayout title={t('recipes.allRecipes', locale)} description={t('recipes.allRecipes', locale)}>
  <section class="py-12 md:py-16">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 text-chocolate">
          {t('recipes.allRecipes', locale)}
        </h1>
        <p class="max-w-lg mx-auto text-slate-600">
          {t(total !== 1 ? 'recipes.countLabelPlural' : 'recipes.countLabelSingular', locale).replace('{count}', String(total))}
        </p>
      </div>

      <h2 class="font-display text-2xl font-bold mb-6 text-chocolate">{t('recipes.browseAll', locale)}</h2>

      <RecipeFilters
        client:load
        initialRecipes={initialRecipes}
        totalRecipes={total}
        initialFacets={facets}
        filterConfig={filterConfig}
        labels={filterLabels}
        locale={locale}
      />

      <!-- Ad: bottom of recipe listing -->
      <div class="mt-12">
        <AdUnit size="leaderboard" slot="recipes-bottom" />
        <AdUnit size="mobile-banner" slot="recipes-bottom-mobile" />
      </div>
    </div>
  </section>
</BaseLayout>
