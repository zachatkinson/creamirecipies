---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';
import { supabase } from '../../lib/supabase';
import { t } from '../../i18n';
import { CATEGORY_COLORS } from '../../lib/blog';
import { translatePostArray } from '../../lib/translations';

export const prerender = false;

const locale = Astro.locals.locale;
const PAGE_SIZE = 12;

// Fetch first page of published posts (only those with past publish dates)
const { data: initialPosts, count } = await supabase
  .from('posts')
  .select('id, title, slug, excerpt, category, hero_image_url, published_at, created_at', { count: 'exact' })
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString())
  .order('published_at', { ascending: false })
  .range(0, PAGE_SIZE - 1);

const posts = (initialPosts ?? []) as Record<string, unknown>[];
const total = count ?? 0;

// Apply translations
await translatePostArray(supabase, posts, locale);

const categoryColors = CATEGORY_COLORS;

const hasMore = posts.length < total;
---

<BaseLayout title={t('blog.title', locale)} description={t('blog.description', locale)}>
  <section class="py-12 md:py-16">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-12">
          <h1 class="font-display text-4xl md:text-5xl font-bold text-chocolate mb-4">
            {t('blog.title', locale)}
          </h1>
          <p class="text-slate-600 max-w-lg mx-auto">
            {t('blog.description', locale)}
          </p>
        </div>
      </ScrollReveal>

      {posts.length > 0 ? (
        <>
          <ScrollReveal animation="stagger" staggerAmount={0.08}>
          <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <BlogPostCard post={post} headingLevel="h2" />
            ))}
          </div>
          </ScrollReveal>

          {hasMore && (
            <div class="text-center mt-10">
              <button
                id="load-more-posts"
                data-page="2"
                data-total={total}
                data-loaded={posts.length}
                data-label={t('home.viewAllPosts', locale)}
                data-colors={JSON.stringify(categoryColors)}
                data-error={t('blog.loadError', locale)}
                data-locale={locale}
                class="px-8 py-3 bg-white text-berry font-medium rounded-full border-2 border-blush hover:bg-blush/10 transition-colors"
              >
                {t('home.viewAllPosts', locale)}
                <span class="ml-2 text-sm text-slate-600">
                  ({posts.length} / {total})
                </span>
              </button>
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-20 bg-white/50 rounded-2xl">
          <span class="text-5xl mb-4 block">📝</span>
          <h2 class="font-display text-2xl font-bold text-chocolate mb-2">{t('blog.comingSoon', locale)}</h2>
          <p class="text-slate-600">{t('blog.comingSoonDesc', locale)}</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('load-more-posts') as HTMLButtonElement | null;
  if (btn) {
    const grid = document.getElementById('blog-grid');
    let page = parseInt(btn.dataset.page ?? '2');
    const total = parseInt(btn.dataset.total ?? '0');
    let loaded = parseInt(btn.dataset.loaded ?? '0');

    const categoryColors: Record<string, string> = JSON.parse(btn.dataset.colors ?? '{}');

    const dateLocale = btn.dataset.locale || 'en';

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      btn.textContent = '\u2026';

      try {
        const res = await fetch(`/api/posts?page=${page}&pageSize=12`);
        const data = await res.json();

        for (const post of data.posts) {
          const heroSrc = post.hero_image_url || `/images/blog/${post.category || 'news'}.svg`;
          const heroBase = heroSrc.replace('.avif', '');
          const isAvif = heroSrc.endsWith('.avif');
          const srcsetAttr = isAvif ? `srcset="${heroBase}-384w.avif 384w, ${heroBase}-768w.avif 768w, ${heroSrc} 1200w" sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 384px"` : '';
          const date = new Date(post.published_at || post.created_at).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', year: 'numeric' });
          const colorClass = categoryColors[post.category] ?? 'bg-slate-100 text-slate-600';

          const card = document.createElement('a');
          card.href = `/blog/${post.slug}`;
          card.className = 'group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1';
          card.innerHTML = `
            <div class="aspect-[16/9] bg-cream-dark overflow-hidden">
              <img src="${heroSrc}" ${srcsetAttr} alt="${post.title}" width="1200" height="675" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-medium px-2.5 py-0.5 rounded-full ${colorClass}">${post.category}</span>
                <time class="text-xs text-slate-600">${date}</time>
              </div>
              <h2 class="font-display text-lg font-bold text-chocolate group-hover:text-berry transition-colors line-clamp-2 mb-2">${post.title}</h2>
              ${post.excerpt ? `<p class="text-sm text-slate-600 line-clamp-3">${post.excerpt}</p>` : ''}
            </div>
          `;
          grid?.appendChild(card);
        }

        loaded += data.posts.length;
        page++;

        if (loaded >= total) {
          btn.remove();
        } else {
          btn.disabled = false;
          const label = btn.dataset.label ?? 'Load More';
          btn.innerHTML = `${label} <span class="ml-2 text-sm text-slate-600">(${loaded} / ${total})</span>`;
        }
      } catch {
        btn.disabled = false;
        btn.textContent = btn.dataset.error || 'Error';
      }
    });
  }
</script>
