---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import AdUnit from '../../components/ads/AdUnit.astro';
import { supabase } from '../../lib/supabase';
import { marked } from 'marked';
import { getPostBySlug, getPostTranslation } from '../../lib/posts';
import { expandShortcodes } from '../../lib/shortcodes';
import { buildBlogPostingJsonLd, type BlogPostForJsonLd } from '../../lib/seo';
import { CATEGORY_COLORS } from '../../lib/blog';
import { ui, translatePostNavigation } from '../../lib/translations';
import { t } from '../../i18n';

export const prerender = false;

const { slug } = Astro.params;
const locale = Astro.locals.locale;
const post = await getPostBySlug(supabase, slug!);

if (!post) {
  return Astro.redirect('/404');
}

// Apply translation if non-English
const postTranslation = await getPostTranslation(supabase, post.id, locale);
if (postTranslation) {
  (post as Record<string, unknown>).title = postTranslation.title;
  if (postTranslation.excerpt) (post as Record<string, unknown>).excerpt = postTranslation.excerpt;
  if (postTranslation.body) (post as Record<string, unknown>).body = postTranslation.body;
}

const heroImage = post.hero_image_url || `/images/blog/${post.category || 'news'}.svg`;
const hasAffiliateLinks = post.body?.includes('[product asin=') ?? false;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Prev/Next posts
const { data: prevPost } = await supabase
  .from('posts')
  .select('title, slug')
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString())
  .lt('published_at', post.published_at ?? post.created_at)
  .order('published_at', { ascending: false })
  .limit(1)
  .single();

const { data: nextPost } = await supabase
  .from('posts')
  .select('title, slug')
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString())
  .gt('published_at', post.published_at ?? post.created_at)
  .order('published_at', { ascending: true })
  .limit(1)
  .single();

// Related posts (same category, excluding current)
const { data: relatedPostsRaw } = await supabase
  .from('posts')
  .select('title, slug, excerpt, category, hero_image_url, published_at, created_at')
  .eq('status', 'published')
  .eq('category', post.category)
  .neq('id', post.id)
  .lte('published_at', new Date().toISOString())
  .order('published_at', { ascending: false })
  .limit(3);

const relatedPosts = (relatedPostsRaw ?? []) as Record<string, unknown>[];

// Translate prev/next/related if non-English
await translatePostNavigation(supabase, locale, prevPost, nextPost, relatedPosts);

const categoryColors = CATEGORY_COLORS;
const blogPostJsonLd = buildBlogPostingJsonLd(post as BlogPostForJsonLd, siteUrl);
const breadcrumbs = [
  { name: t('breadcrumb.home', locale), url: siteUrl },
  { name: t('blog.title', locale), url: `${siteUrl}/blog` },
  { name: post.title, url: `${siteUrl}/blog/${post.slug}` },
];
---

<BaseLayout
  title={post.title}
  description={post.excerpt ?? undefined}
  image={post.hero_image_url ?? undefined}
  type="article"
  jsonLd={blogPostJsonLd}
  breadcrumbs={breadcrumbs}
>
  <article class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-600 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-berry transition-colors">{t('breadcrumb.home', locale)}</a>
        <span aria-hidden="true">/</span>
        <a href="/blog" class="hover:text-berry transition-colors">{t('blog.title', locale)}</a>
        <span aria-hidden="true">/</span>
        <span class="text-slate-700 truncate" aria-current="page">{post.title}</span>
      </nav>

      <ScrollReveal>
        <!-- Meta -->
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-medium px-3 py-1 rounded-full bg-lavender/20 text-lavender-dark">
            {t(`blog.${post.category}`, locale)}
          </span>
          <time class="text-sm text-slate-600" datetime={post.published_at ?? post.created_at}>
            {new Date(post.published_at ?? post.created_at).toLocaleDateString(locale, {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            })}
          </time>
        </div>

        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-chocolate mb-6">
          {post.title}
        </h1>

        <!-- Author -->
        <div class="flex items-center gap-3 mb-8 pb-8 border-b border-slate-100">
          <div class="w-10 h-10 rounded-full bg-lavender/20 flex items-center justify-center text-lavender-dark font-bold text-sm" aria-hidden="true">
            C
          </div>
          <div>
            <div class="text-sm font-medium" style="color: #5C3D2E">
              eatcreami Team
            </div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Hero Image -->
      <ScrollReveal animation="fade-up" delay={0.1}>
        <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-10">
          <img src={heroImage} alt={post.title} width={1200} height={675} class="w-full h-full object-cover" />
        </div>
      </ScrollReveal>

      <!-- Affiliate Disclosure -->
      {hasAffiliateLinks && (
        <div class="flex items-start gap-3 p-4 mb-8 bg-vanilla/20 border border-vanilla/40 rounded-xl">
          <svg class="w-5 h-5 text-chocolate-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <span class="text-sm font-bold text-chocolate">{ui('affiliateNotice', locale)}</span>
            <p class="text-xs text-slate-600 mt-0.5">{ui('affiliateDisclosure', locale)}</p>
          </div>
        </div>
      )}

      <!-- Body -->
      <ScrollReveal animation="fade-up" delay={0.15}>
        <div class="prose prose-lg max-w-none text-slate-700 prose-headings:text-chocolate prose-headings:font-display prose-a:text-berry hover:prose-a:text-berry/80 prose-strong:text-chocolate" set:html={await expandShortcodes(marked.parse(post.body) as string, supabase, locale)} />
      </ScrollReveal>

      <!-- Ad: bottom of blog post -->
      <AdUnit size="in-article" slot="post-bottom" class="mt-12" />

      <!-- Prev/Next Navigation -->
      {(prevPost || nextPost) && (
        <nav class="mt-12 pt-8 border-t border-slate-100" aria-label="Article navigation">
          <div class="flex justify-between gap-6">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}`} class="group flex-1 min-w-0">
                <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">{ui('previousArticle', locale)}</span>
                <p class="text-sm font-medium text-chocolate group-hover:text-berry transition-colors truncate mt-1">
                  {prevPost.title}
                </p>
              </a>
            ) : <div class="flex-1" />}
            {nextPost ? (
              <a href={`/blog/${nextPost.slug}`} class="group flex-1 min-w-0 text-right">
                <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">{ui('nextArticle', locale)}</span>
                <p class="text-sm font-medium text-chocolate group-hover:text-berry transition-colors truncate mt-1">
                  {nextPost.title}
                </p>
              </a>
            ) : <div class="flex-1" />}
          </div>
        </nav>
      )}
    </div>
  </article>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-12 bg-cream/30">
      <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
        <ScrollReveal>
          <h2 class="font-display text-2xl font-bold text-chocolate mb-8 text-center">
            {ui('relatedArticles', locale)}
          </h2>
        </ScrollReveal>
        <ScrollReveal animation="stagger" staggerAmount={0.1}>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map((rp) => (
              <a
                href={`/blog/${rp.slug}`}
                class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
              >
                <div class="aspect-[16/9] bg-cream-dark overflow-hidden">
                  {rp.hero_image_url ? (() => {
                    const src = rp.hero_image_url as string;
                    const base = src.replace('.avif', '');
                    return (
                      <img
                        src={src}
                        srcset={`${base}-384w.avif 384w, ${base}-768w.avif 768w, ${src} 1200w`}
                        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 384px"
                        alt={rp.title as string}
                        width={1200}
                        height={675}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    );
                  })() : (
                    <img
                      src={`/images/blog/${(rp.category as string) || 'news'}.svg`}
                      alt={rp.title as string}
                      width={1200}
                      height={675}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', categoryColors[rp.category as string] ?? 'bg-slate-100 text-slate-600']}>
                      {t(`blog.${rp.category}`, locale)}
                    </span>
                    <time class="text-xs text-slate-600" datetime={rp.published_at as string}>
                      {new Date((rp.published_at ?? rp.created_at) as string).toLocaleDateString(locale, { month: 'short', day: 'numeric', year: 'numeric' })}
                    </time>
                  </div>
                  <h3 class="font-display text-lg font-bold text-chocolate group-hover:text-berry transition-colors line-clamp-2 mb-2">
                    {rp.title}
                  </h3>
                  {rp.excerpt && (
                    <p class="text-sm text-slate-600 line-clamp-2">{rp.excerpt}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </section>
  )}
</BaseLayout>
