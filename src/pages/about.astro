---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ScrollReveal from '../components/animations/ScrollReveal.astro';
import { buildFaqJsonLd } from '../lib/seo';
import { t } from '../i18n';

const locale = Astro.locals.locale;

const faqs = [
  { question: t('about.faq1q', locale), answer: t('about.faq1a', locale) },
  { question: t('about.faq2q', locale), answer: t('about.faq2a', locale) },
  { question: t('about.faq3q', locale), answer: t('about.faq3a', locale) },
  { question: t('about.faq4q', locale), answer: t('about.faq4a', locale) },
  { question: t('about.faq5q', locale), answer: t('about.faq5a', locale) },
  { question: t('about.faq6q', locale), answer: t('about.faq6a', locale) },
];

const faqJsonLd = buildFaqJsonLd(faqs);
---

<BaseLayout title={t('about.title', locale)} description={t('about.intro', locale)} jsonLd={faqJsonLd}>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-8 text-center text-chocolate">
          {t('about.title', locale)}
        </h1>
      </ScrollReveal>

      <ScrollReveal animation="fade-up" delay={0.1}>
        <div class="prose prose-lg max-w-none text-slate-800">
          <p>
            {t('about.intro', locale)}
          </p>

          <h2 class="font-display text-2xl font-bold text-chocolate mt-10 mb-4">{t('about.whatMakesUs', locale)}</h2>

          <ul class="space-y-4">
            <li>
              <strong class="text-chocolate">{t('about.stepByStep', locale)}</strong> — {t('about.stepByStepDesc', locale)}
            </li>
            <li>
              <strong class="text-chocolate">{t('about.cookMode', locale)}</strong> — {t('about.cookModeDesc', locale)}
            </li>
            <li>
              <strong class="text-chocolate">{t('about.ratings', locale)}</strong> — {t('about.ratingsDesc', locale)}
            </li>
            <li>
              <strong class="text-chocolate">{t('about.modelCompat', locale)}</strong> — {t('about.modelCompatDesc', locale)}
            </li>
          </ul>

          <h2 class="font-display text-2xl font-bold text-chocolate mt-10 mb-4">{t('about.joinTitle', locale)}</h2>

          <p>
            {t('about.joinDesc', locale)}
          </p>
        </div>
      </ScrollReveal>

      <!-- FAQ Section -->
      <ScrollReveal animation="fade-up" delay={0.15}>
        <div class="mt-14">
          <h2 class="font-display text-2xl font-bold text-chocolate mb-6">{t('about.faqTitle', locale)}</h2>
          <div class="space-y-3">
            {faqs.map((faq) => (
              <details class="group bg-white rounded-xl border border-slate-100 shadow-sm">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer text-sm font-semibold text-chocolate hover:text-berry transition-colors">
                  {faq.question}
                  <svg class="w-4 h-4 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-sm text-slate-600 leading-relaxed">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal animation="fade-up" delay={0.2}>
        <div class="mt-12 text-center">
          <a
            href="/recipes"
            class="inline-block px-8 py-3.5 bg-berry text-white font-semibold rounded-full hover:bg-berry/90 transition-colors shadow-lg shadow-berry/25"
          >
            {t('about.exploreRecipes', locale)}
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
