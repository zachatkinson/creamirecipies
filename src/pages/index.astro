---
import BaseLayout from '../components/layout/BaseLayout.astro';
import RecipeCard from '../components/recipe/RecipeCard.astro';
import ScrollReveal from '../components/animations/ScrollReveal.astro';
import AdUnit from '../components/ads/AdUnit.astro';
import HeroCanvas from '../components/animations/HeroCanvas';
import { supabase } from '../lib/supabase';
import { getCategories } from '../lib/recipes';
import { t } from '../i18n';
import { ui, translateRecipeArray, translatePostArray } from '../lib/translations';

const locale = Astro.locals.locale;
const categories = await getCategories(supabase);

// Get base types that actually have published recipes
const { data: baseTypeCounts } = await supabase
  .from('recipes')
  .select('base_type')
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString());

const activeBaseTypes = new Set(baseTypeCounts?.map((r) => r.base_type) ?? []);

// Get total published recipe count for hero stat
const { count: recipeCount } = await supabase
  .from('recipes')
  .select('id', { count: 'exact', head: true })
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString());

// Get latest 6 published recipes (newest first)
const { data: latestRecipesRaw } = await supabase
  .from('recipes')
  .select(`
    id, title, slug, description, difficulty, base_type,
    hero_image_url, avg_rating, rating_count,
    prep_time_minutes, freeze_time_hours,
    is_sponsored, sponsor_name, sponsor_logo_url,
    author:profiles!author_id (username, display_name, avatar_url)
  `)
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString())
  .order('published_at', { ascending: false })
  .limit(6);

const recipes = (latestRecipesRaw ?? []) as Record<string, unknown>[];

// Get latest 3 published blog posts
const { data: latestPostsRaw } = await supabase
  .from('posts')
  .select('id, title, slug, excerpt, category, hero_image_url, published_at, created_at')
  .eq('status', 'published')
  .lte('published_at', new Date().toISOString())
  .order('published_at', { ascending: false })
  .limit(3);

const posts = (latestPostsRaw ?? []) as Record<string, unknown>[];

const baseTypes = categories.filter((c) => c.type === 'base_type' && activeBaseTypes.has(c.name));

// Apply translations if non-English
await translateRecipeArray(supabase, recipes, locale);
await translatePostArray(supabase, posts, locale);

import BlogPostCard from '../components/blog/BlogPostCard.astro';
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-cream via-blush/10 to-lavender/10 hero-gradient-animated">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
      <div class="max-w-2xl relative z-10">
        <ScrollReveal animation="scale" delay={0.05}>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-blush/20 text-berry text-sm font-medium rounded-full mb-6">
            <span data-count-to={recipeCount ?? 0} data-count-suffix="+">0+</span>
            {t('home.badge', locale)}
          </span>
        </ScrollReveal>
        <ScrollReveal animation="fade-up" delay={0.15} duration={1}>
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold text-chocolate leading-tight mb-6">
            {t('home.heroTitle', locale)}
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blush-dark to-berry">
              {t('home.heroTitleAccent', locale)}
            </span>
          </h1>
        </ScrollReveal>
        <ScrollReveal animation="fade-up" delay={0.2}>
          <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed">
            {t('home.heroDescription', locale)}
          </p>
        </ScrollReveal>
        <ScrollReveal animation="fade-up" delay={0.3}>
          <div class="flex flex-wrap gap-4">
            <a
              href="/recipes"
              class="px-8 py-3.5 bg-berry text-white font-semibold rounded-full hover:bg-berry/90 transition-colors shadow-lg shadow-berry/25"
            >
              {t('home.browseRecipes', locale)}
            </a>
          </div>
        </ScrollReveal>
      </div>

      <!-- Decorative elements (PixiJS only loads on desktop to save ~73kB on mobile) -->
      <div class="hidden md:block absolute right-0 top-0 w-1/2 h-full opacity-30 pointer-events-none" id="hero-canvas-container">
        <HeroCanvas client:media="(min-width: 768px)" />
      </div>

      <!-- Hero swirl image -->
      <div class="hidden md:block absolute right-8 lg:right-16 top-1/2 -translate-y-1/2 w-64 lg:w-80 xl:w-96 pointer-events-none z-[1]">
        <ScrollReveal animation="fade-in" delay={0.4}>
          <img
            src="/images/hero-swirl.avif"
            srcset="/images/hero-swirl-384w.avif 384w, /images/hero-swirl-768w.avif 768w, /images/hero-swirl.avif 800w"
            sizes="(max-width: 1024px) 256px, (max-width: 1280px) 320px, 384px"
            alt=""
            aria-hidden="true"
            width={800}
            height={1200}
            class="w-full h-auto drop-shadow-2xl"
            loading="eager"
            fetchpriority="high"
          />
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- Category Quick Links -->
  <section class="py-12 bg-white/50">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal animation="stagger">
        <div class="flex flex-wrap justify-center gap-3">
          {baseTypes.map((cat) => (
            <a
              href={`/recipes?base=${cat.slug}`}
              class="px-5 py-2.5 bg-white rounded-full text-sm font-medium text-slate-600 hover:text-berry hover:bg-blush/15 border border-slate-200 hover:border-blush transition-all"
            >
              {ui(cat.name, locale)}
            </a>
          ))}
          <a
            href="/recipes?tag=soft-serve"
            class="px-5 py-2.5 bg-white rounded-full text-sm font-medium text-slate-600 hover:text-berry hover:bg-blush/15 border border-slate-200 hover:border-blush transition-all"
          >
            {ui('Soft Serve', locale)}
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Latest Recipes -->
  <section class="py-16 md:py-24">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-chocolate mb-4">
            {t('home.featuredTitle', locale)}
          </h2>
          <p class="text-slate-600 max-w-lg mx-auto">
            {t('home.featuredDescription', locale)}
          </p>
        </div>
      </ScrollReveal>

      {recipes.length > 0 ? (
        <ScrollReveal animation="stagger" staggerAmount={0.08}>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {recipes.map((recipe) => (
              <RecipeCard recipe={recipe} />
            ))}
          </div>
        </ScrollReveal>
      ) : (
        <div class="text-center py-16 bg-white/50 rounded-2xl">
          <span class="text-5xl mb-4 block">🍨</span>
          <h3 class="font-display text-xl font-bold text-chocolate mb-2">{t('home.comingSoon', locale)}</h3>
          <p class="text-slate-600 mb-6">{t('home.comingSoonDesc', locale)}</p>
          <a href="/recipes" class="inline-block px-6 py-3 bg-berry text-white font-medium rounded-full hover:bg-berry/90 transition-colors">
            {t('home.browseAll', locale)}
          </a>
        </div>
      )}

      {recipes.length > 0 && (
        <div class="text-center mt-10">
          <a
            href="/recipes"
            class="inline-flex items-center gap-2 px-6 py-3 text-berry font-medium hover:bg-blush/10 rounded-full transition-colors"
          >
            {t('home.viewAll', locale)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Ad: between recipes and blog -->
  <div class="max-w-[var(--container-max)] mx-auto px-4 py-6">
    <AdUnit size="leaderboard" slot="home-mid" />
    <AdUnit size="mobile-banner" slot="home-mid-mobile" />
  </div>

  <!-- Latest from the Blog -->
  {posts.length > 0 && (
    <section class="py-16 md:py-24 bg-white/50">
      <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
        <ScrollReveal>
          <div class="text-center mb-12">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-chocolate mb-4">
              {t('home.latestNewsTitle', locale)}
            </h2>
            <p class="text-slate-600 max-w-lg mx-auto">
              {t('home.latestNewsDescription', locale)}
            </p>
          </div>
        </ScrollReveal>

        <ScrollReveal animation="stagger" staggerAmount={0.1}>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {posts.map((post) => (
              <BlogPostCard post={post} />
            ))}
          </div>
        </ScrollReveal>

        <div class="text-center mt-10">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-6 py-3 text-berry font-medium hover:bg-blush/10 rounded-full transition-colors"
          >
            {t('home.viewAllPosts', locale)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- How It Works -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-white/50 to-cream">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <div class="text-center mb-14">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-chocolate mb-4">
            {t('home.howItWorksTitle', locale)}
          </h2>
          <p class="text-slate-600 max-w-lg mx-auto">
            {t('home.howItWorksDescription', locale)}
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal animation="stagger" staggerAmount={0.15}>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center p-8 bg-white rounded-2xl shadow-sm">
            <div class="w-16 h-16 bg-mint/20 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-3xl">📖</span>
            </div>
            <h3 class="font-display text-lg font-bold text-chocolate mb-2">{t('home.chooseRecipe', locale)}</h3>
            <p class="text-sm text-slate-600">
              {t('home.chooseRecipeDesc', locale)}
            </p>
          </div>
          <div class="text-center p-8 bg-white rounded-2xl shadow-sm">
            <div class="w-16 h-16 bg-blush/20 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-3xl">👨‍🍳</span>
            </div>
            <h3 class="font-display text-lg font-bold text-chocolate mb-2">{t('home.followSteps', locale)}</h3>
            <p class="text-sm text-slate-600">
              {t('home.followStepsDesc', locale)}
            </p>
          </div>
          <div class="text-center p-8 bg-white rounded-2xl shadow-sm">
            <div class="w-16 h-16 bg-lavender/20 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-3xl">⭐</span>
            </div>
            <h3 class="font-display text-lg font-bold text-chocolate mb-2">{t('home.rateShare', locale)}</h3>
            <p class="text-sm text-slate-600">
              {t('home.rateShareDesc', locale)}
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal animation="scale" duration={0.9}>
        <div class="bg-gradient-to-r from-berry to-blush-dark rounded-3xl p-10 md:p-16 text-center text-white">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">
            {t('home.ctaTitle', locale)}
          </h2>
          <p class="text-white/80 max-w-lg mx-auto mb-8 text-lg">
            {t('home.ctaDescription', locale)}
          </p>
          <a
            href="/recipes"
            class="inline-block px-8 py-3.5 bg-white text-berry font-semibold rounded-full hover:bg-cream transition-colors shadow-lg"
          >
            {t('home.ctaButton', locale)}
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
