---
/**
 * Universal ad unit component with IAB standard sizes.
 *
 * Sizes (IAB Standard Ad Units):
 * - leaderboard:      728x90  (desktop top/bottom of page)
 * - mobile-banner:    320x50  (mobile top/bottom)
 * - medium-rectangle: 300x250 (sidebar, in-content)
 * - large-rectangle:  336x280 (in-content, higher CPM)
 * - half-page:        300x600 (sidebar sticky)
 * - in-article:       responsive (between content blocks)
 * - anchor:           320x50  (sticky bottom mobile)
 *
 * When ads are not active, renders a subtle placeholder in dev
 * and nothing in production.
 */

type AdSize =
  | 'leaderboard'
  | 'mobile-banner'
  | 'medium-rectangle'
  | 'large-rectangle'
  | 'half-page'
  | 'in-article';

interface Props {
  size: AdSize;
  slot?: string;
  class?: string;
  lazy?: boolean;
}

const { size, slot: adSlot = 'default', class: className = '', lazy = true } = Astro.props;

const isDev = import.meta.env.DEV;

const sizeConfig: Record<AdSize, { width: string; height: string; minHeight: string; label: string; responsive?: boolean }> = {
  'leaderboard':      { width: '728px', height: '90px',  minHeight: '90px',  label: '728x90 Leaderboard' },
  'mobile-banner':    { width: '320px', height: '50px',  minHeight: '50px',  label: '320x50 Mobile Banner' },
  'medium-rectangle': { width: '300px', height: '250px', minHeight: '250px', label: '300x250 Medium Rectangle' },
  'large-rectangle':  { width: '336px', height: '280px', minHeight: '280px', label: '336x280 Large Rectangle' },
  'half-page':        { width: '300px', height: '600px', minHeight: '600px', label: '300x600 Half Page' },
  'in-article':       { width: '100%',  height: 'auto',  minHeight: '250px', label: 'In-Article (Responsive)', responsive: true },
};

const config = sizeConfig[size];
---

<div
  class:list={[
    'ad-zone',
    `ad-${size}`,
    className,
    // Hide on wrong viewport
    size === 'leaderboard' && 'hidden md:block',
    size === 'mobile-banner' && 'block md:hidden',
    size === 'half-page' && 'hidden lg:block',
  ]}
  data-ad-slot={adSlot}
  data-ad-size={size}
  data-ad-lazy={lazy}
  aria-hidden="true"
  role="complementary"
  aria-label="Advertisement"
  style={`max-width: ${config.width}; ${isDev ? `min-height: ${config.minHeight};` : ''} margin: 0 auto;`}
>
  {isDev ? (
    <!-- Dev placeholder: shows ad size for layout planning -->
    <div
      class="flex items-center justify-center border-2 border-dashed border-slate-300 rounded-lg bg-slate-50/50 text-slate-500 text-xs font-mono select-none"
      style={`width: 100%; height: ${config.responsive ? config.minHeight : config.height}; max-width: ${config.width};`}
    >
      AD: {config.label}
    </div>
  ) : (
    <!-- Production: ad network script will fill this, min-height set by ad script -->
    <div
      class="ad-container"
      style={`width: 100%; max-width: ${config.width};`}
    >
      <!-- Ad code injected by ad network script in BaseLayout -->
    </div>
  )}
</div>
