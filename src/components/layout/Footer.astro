---
import { t, localePath } from '../../i18n';

const locale = Astro.locals.locale;
const lp = (path: string) => localePath(path, locale);
const currentYear = new Date().getFullYear();
---

<footer class="bg-chocolate text-cream/80 mt-auto">
  <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={lp('/')} class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🍦</span>
          <span class="font-display text-lg font-bold text-cream">eatcreami</span>
        </a>
        <p class="text-sm text-cream/80">
          {t('footer.description', locale)}
        </p>
      </div>

      <!-- Recipes -->
      <div>
        <h2 class="font-display text-sm font-bold text-white mb-4 uppercase tracking-wider">{t('footer.recipes', locale)}</h2>
        <ul class="space-y-2 text-sm">
          <li><a href={lp('/recipes')} class="hover:text-cream transition-colors">{t('footer.allRecipes', locale)}</a></li>
          <li><a href={lp('/recipes?base=ice-cream')} class="hover:text-cream transition-colors">{t('footer.iceCream', locale)}</a></li>
          <li><a href={lp('/recipes?base=sorbet')} class="hover:text-cream transition-colors">{t('footer.sorbet', locale)}</a></li>
          <li><a href={lp('/recipes?base=gelato')} class="hover:text-cream transition-colors">{t('footer.gelato', locale)}</a></li>
          <li><a href={lp('/recipes?base=frozen-yogurt')} class="hover:text-cream transition-colors">{t('footer.frozenYogurt', locale)}</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h2 class="font-display text-sm font-bold text-white mb-4 uppercase tracking-wider">{t('footer.community', locale)}</h2>
        <ul class="space-y-2 text-sm">
          <li><a href={lp('/about')} class="hover:text-cream transition-colors">{t('footer.aboutUs', locale)}</a></li>
          <li><a href={lp('/blog')} class="hover:text-cream transition-colors">{t('footer.blog', locale)}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h2 class="font-display text-sm font-bold text-white mb-4 uppercase tracking-wider">{t('footer.legal', locale)}</h2>
        <ul class="space-y-2 text-sm">
          <li><a href={lp('/privacy')} class="hover:text-cream transition-colors">{t('footer.privacyPolicy', locale)}</a></li>
          <li><a href={lp('/terms')} class="hover:text-cream transition-colors">{t('footer.termsOfUse', locale)}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-cream/10 text-center text-sm text-cream/70">
      <p>&copy; {currentYear} {t('site.name', locale)}. {t('footer.disclaimer', locale)}</p>
    </div>
  </div>
</footer>
