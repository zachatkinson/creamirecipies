---
import { LOCALES, type Locale } from '../../i18n';
import { ui } from '../../lib/translations';

const currentLocale = Astro.locals.locale;
const localeEntries = Object.entries(LOCALES) as [Locale, typeof LOCALES[Locale]][];
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-btn"
    class="flex items-center gap-1.5 px-3 py-1.5 text-sm text-slate-600 hover:text-chocolate rounded-full border border-slate-200 hover:border-blush transition-colors"
    aria-label={`${LOCALES[currentLocale].label} - ${ui('changeLanguage', currentLocale)}`}
    aria-expanded="false"
  >
    <span>{LOCALES[currentLocale].flag}</span>
    <span class="hidden sm:inline">{LOCALES[currentLocale].label}</span>
    <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="lang-dropdown"
    class="hidden absolute right-0 top-full mt-1 bg-white rounded-xl shadow-lg border border-slate-100 py-1 z-50 min-w-[160px]"
  >
    {localeEntries.map(([code, { label, flag }]) => (
      <button
        class:list={[
          'w-full flex items-center gap-2 px-4 py-2 text-sm text-left hover:bg-cream transition-colors',
          code === currentLocale ? 'text-berry font-medium bg-blush/10' : 'text-slate-600',
        ]}
        data-locale={code}
      >
        <span>{flag}</span>
        <span>{label}</span>
        {code === currentLocale && (
          <svg class="w-3.5 h-3.5 ml-auto text-berry" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        )}
      </button>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');

  btn?.addEventListener('click', () => {
    const isOpen = dropdown?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('lang-switcher')?.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Handle locale selection
  dropdown?.querySelectorAll('[data-locale]').forEach((el) => {
    el.addEventListener('click', async () => {
      const locale = (el as HTMLElement).dataset.locale;
      document.cookie = `locale=${locale}; path=/; max-age=${60 * 60 * 24 * 365}`;
      window.location.reload();
    });
  });
</script>
