---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';

import { buildWebSiteJsonLd, buildOrganizationJsonLd, buildBreadcrumbJsonLd } from '../../lib/seo';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, localePath, type Locale } from '../../i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean;
}

const {
  title,
  description = 'Discover and share delicious Ninja Creami recipes. Step-by-step guidance, ratings, and pro tips for perfect frozen treats every time.',
  image = '/og-default.avif',
  type = 'website',
  jsonLd,
  breadcrumbs,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const locale = Astro.locals.locale;
const isHome = title === 'Home';
const currentPath = Astro.url.pathname;

// For locale pages, the canonical includes the locale prefix
const localePrefixRe = /^\/(fr|es|de|pt)(\/|$)/;
const pathMatch = currentPath.match(localePrefixRe);
const basePath = pathMatch ? currentPath.slice(pathMatch[1].length + 1) || '/' : currentPath;
const canonicalPath = localePath(basePath, locale);
const canonicalUrl = new URL(canonicalPath, Astro.site);
const fullTitle = title === 'Home' ? 'eatcreami — Ninja Creami Recipes & Frozen Treats' : `${title} | eatcreami`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Hreflang: cross-reference all locale versions -->
    {SUPPORTED_LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={`${siteUrl}${localePath(basePath, loc)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${basePath}`} />

    <!-- Webmaster verification done via DNS (no meta tags needed) -->

    <!-- Fonts (self-hosted, loaded via fonts.css) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="eatcreami" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Pinterest Rich Pins -->
    <meta name="pinterest-rich-pin" content="true" />

    <!-- Favicon + PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="eatcreami" href="/rss.xml" />

    <!-- Mobile / PWA -->
    <meta name="theme-color" content="#FFF8F0" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="eatcreami" />
    <meta name="application-name" content="eatcreami" />
    <meta name="msapplication-TileColor" content="#FFF8F0" />

    <!-- Google Analytics (PLACEHOLDER: replace with real GA4 ID) -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-PLACEHOLDER"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PLACEHOLDER');
    </script> -->

    <noscript><style>.scroll-reveal { opacity: 1 !important; }</style></noscript>
    <title>{fullTitle}</title>

    {/* Page-specific JSON-LD */}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {/* WebSite + Organization JSON-LD (homepage only) */}
    {isHome && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify(buildWebSiteJsonLd(siteUrl))} />
        <script type="application/ld+json" set:html={JSON.stringify(buildOrganizationJsonLd(siteUrl))} />
      </>
    )}

    {/* BreadcrumbList JSON-LD */}
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbJsonLd(breadcrumbs))} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content (WCAG 2.4.1) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-berry focus:text-white focus:rounded-lg focus:text-sm focus:font-medium focus:shadow-lg"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>
    <Footer />

    <!-- Register Service Worker -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
    <!-- Print: open all details elements so FAQ answers are visible -->
    <script>
      window.addEventListener('beforeprint', () => {
        document.querySelectorAll('details').forEach(d => d.setAttribute('open', ''));
      });
    </script>

    <!-- Smooth FAQ accordion transitions -->
    <script>
      import { gsap } from 'gsap';

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      document.querySelectorAll('details').forEach((details) => {
        const summary = details.querySelector('summary');
        const content = details.querySelector('summary + div, summary + p');
        if (!summary || !content) return;

        summary.addEventListener('click', (e) => {
          if (prefersReducedMotion) return; // let native behavior handle it

          e.preventDefault();
          if (details.open) {
            // Close
            gsap.to(content, {
              height: 0, opacity: 0, duration: 0.25, ease: 'power2.inOut',
              onComplete: () => { details.open = false; gsap.set(content, { clearProps: 'all' }); },
            });
          } else {
            // Open
            details.open = true;
            const naturalHeight = content.scrollHeight;
            gsap.fromTo(content,
              { height: 0, opacity: 0 },
              { height: naturalHeight, opacity: 1, duration: 0.3, ease: 'power2.out',
                onComplete: () => gsap.set(content, { clearProps: 'all' }) },
            );
          }
        });
      });
    </script>

    <!-- Magnetic CTA hover (desktop only) -->
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && window.innerWidth >= 768) {
        document.querySelectorAll('a.magnetic-hover, [data-magnetic]').forEach((el) => {
          const btn = el as HTMLElement;
          btn.addEventListener('mousemove', (e) => {
            const rect = btn.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            btn.style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
          });
          btn.addEventListener('mouseleave', () => {
            btn.style.transform = '';
            btn.style.transition = 'transform 0.3s ease-out';
            setTimeout(() => { btn.style.transition = ''; }, 300);
          });
        });
      }
    </script>
  </body>
</html>
