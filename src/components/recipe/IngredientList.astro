---
import type { Ingredient } from '../../lib/types';
import { INGREDIENT_GROUP_ORDER, INGREDIENT_GROUP_LABELS } from '../../lib/blog';

interface Props {
  ingredients: Ingredient[];
}

const { ingredients } = Astro.props;
const locale = Astro.locals.locale ?? 'en';

// Group ingredients by group_name
const groups = ingredients.reduce<Record<string, Ingredient[]>>((acc, ing) => {
  const group = ing.group_name || 'base';
  if (!acc[group]) acc[group] = [];
  acc[group].push(ing);
  return acc;
}, {});

const sortedGroups = INGREDIENT_GROUP_ORDER.filter((g) => groups[g]);
---

<div class="space-y-6">
  {sortedGroups.map((groupName) => (
    <div>
      {sortedGroups.length > 1 && (
        <h4 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">
          {INGREDIENT_GROUP_LABELS[groupName]?.[locale] ?? INGREDIENT_GROUP_LABELS[groupName]?.en ?? groupName}
        </h4>
      )}
      <ul class="space-y-2">
        {groups[groupName].map((ingredient) => (
          <li class="ingredient-item flex items-start gap-3 py-2 border-b border-slate-50 last:border-0">
            <span class="flex-shrink-0 w-5 h-5 mt-0.5 rounded-full border-2 border-blush/40" />
            <div class="flex-1">
              <span class="font-medium text-slate-700">{ingredient.name}</span>
              <span class="ml-2 text-sm text-slate-500">
                {ingredient.amount}{ingredient.unit ? ` ${ingredient.unit}` : ''}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
