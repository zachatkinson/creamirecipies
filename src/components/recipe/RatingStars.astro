---
interface Props {
  rating: number;
  size?: 'sm' | 'md' | 'lg';
  showValue?: boolean;
}

const { rating, size = 'md', showValue = false } = Astro.props;

const sizes = {
  sm: 'w-3.5 h-3.5',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const starSize = sizes[size];
const maxStars = 5;
const fraction = rating - Math.floor(rating);
const fullStars = fraction >= 0.75 ? Math.floor(rating) + 1 : Math.floor(rating);
const hasHalf = fraction >= 0.25 && fraction < 0.75;
const emptyStars = maxStars - fullStars - (hasHalf ? 1 : 0);
const gradientId = `half-star-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="flex items-center gap-0.5" role="img" aria-label={`${rating.toFixed(1)} out of 5 stars`}>
  {Array.from({ length: fullStars }).map(() => (
    <svg class:list={[starSize, 'text-vanilla-dark']} fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  ))}
  {hasHalf && (
    <svg class:list={[starSize, 'text-vanilla-dark']} viewBox="0 0 20 20">
      <defs>
        <linearGradient id={gradientId}>
          <stop offset="50%" stop-color="currentColor" />
          <stop offset="50%" stop-color="#E2E8F0" />
        </linearGradient>
      </defs>
      <path fill={`url(#${gradientId})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  )}
  {Array.from({ length: emptyStars }).map(() => (
    <svg class:list={[starSize, 'text-slate-200']} fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  ))}
  {showValue && (
    <span class="ml-1 text-sm font-medium text-slate-600">{rating.toFixed(1)}</span>
  )}
</div>
