---
import type { RecipeCard as RecipeCardType } from '../../lib/types';
import RatingStars from './RatingStars.astro';
import { ui } from '../../lib/translations';
import { DIFFICULTY_COLORS } from '../../lib/blog';
import { buildRecipeImageSrcset } from '../../lib/images';
import { localePath } from '../../i18n';

interface Props {
  recipe: RecipeCardType;
}

const { recipe } = Astro.props;
const locale = Astro.locals.locale;
const difficultyColors = DIFFICULTY_COLORS;
const imageData = recipe.hero_image_url
  ? buildRecipeImageSrcset(recipe.hero_image_url)
  : null;
---

<a
  href={localePath(`/recipes/${recipe.slug}`, locale)}
  class="recipe-card group flex flex-col relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
>
  <!-- Sponsored Badge -->
  {recipe.is_sponsored && (
    <div class="absolute top-3 left-3 z-10 flex items-center gap-1.5 px-2.5 py-1 bg-white/90 backdrop-blur-sm rounded-full shadow-sm">
      {recipe.sponsor_logo_url && (
        <img src={recipe.sponsor_logo_url} alt={recipe.sponsor_name ?? ui('sponsor', locale)} class="w-4 h-4 rounded-full object-contain" />
      )}
      <span class="text-[10px] font-medium text-slate-600 uppercase tracking-wider">{ui('sponsor', locale)}</span>
    </div>
  )}

  <!-- Image -->
  <div class="aspect-[4/3] bg-cream-dark overflow-hidden">
    {imageData ? (
      <img
        src={imageData.src}
        srcset={imageData.srcset}
        sizes={imageData.sizes}
        alt={recipe.title}
        width={600}
        height={450}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-5xl bg-gradient-to-br from-blush/20 to-lavender/20">
        🍦
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <!-- Meta -->
    <div class="flex items-center gap-2 mb-2">
      <span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', difficultyColors[recipe.difficulty]]}>
        {ui(recipe.difficulty, locale)}
      </span>
      <span class="text-xs text-slate-600">{ui(recipe.base_type, locale)}</span>
    </div>

    <!-- Title -->
    <h3 class="font-display text-lg font-bold text-chocolate group-hover:text-berry transition-colors line-clamp-2 mb-1.5">
      {recipe.title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-600 line-clamp-2 mb-3 flex-1">
      {recipe.description}
    </p>

    <!-- Footer (always at bottom) -->
    <div class="flex items-center justify-between pt-3 border-t border-slate-100 mt-auto">
      <div class="flex items-center gap-2">
        <RatingStars rating={recipe.avg_rating} size="sm" />
        <span class="text-xs text-slate-600">({recipe.rating_count})</span>
      </div>
      <div class="flex items-center gap-3 text-xs text-slate-600">
        {recipe.prep_time_minutes && (
          <span>⏱ {recipe.prep_time_minutes}m {ui('prep', locale).toLowerCase()}</span>
        )}
      </div>
    </div>
  </div>
</a>
