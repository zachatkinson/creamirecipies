{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/recipes/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/recipes/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/images/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/indexnow/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/set-locale/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/recipes/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/recipes/?$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/sitemap\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}