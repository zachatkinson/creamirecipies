---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export const prerender = false;

const { user, profile, supabase } = Astro.locals;

if (!user || !profile || !['admin', 'moderator'].includes(profile.role)) {
  return Astro.redirect('/');
}

const statusFilter = Astro.url.searchParams.get('status') ?? 'pending';

const { data: rawRecipes } = await supabase
  .from('recipes')
  .select(`
    id, title, slug, description, difficulty, base_type, status, created_at,
    author:profiles!author_id (username, display_name)
  `)
  .eq('status', statusFilter)
  .order('created_at', { ascending: false });

interface AdminRecipe {
  id: string;
  title: string;
  description: string;
  difficulty: string;
  base_type: string;
  status: string;
  created_at: string;
  author: { username: string; display_name: string | null } | null;
}

const recipes: AdminRecipe[] = (rawRecipes ?? []) as unknown as AdminRecipe[];

const statusTabs = ['pending', 'published', 'rejected', 'draft'];

const statusColors: Record<string, string> = {
  pending: 'bg-vanilla/40 text-[#5C3D2E]',
  published: 'bg-mint/40 text-[#1a6b4f]',
  rejected: 'bg-red-50 text-red-600',
  draft: 'bg-slate-100 text-slate-600',
};
---

<BaseLayout title="Review Recipes">
  <section class="py-12">
    <div class="max-w-[var(--container-max)] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="font-display text-3xl font-bold text-chocolate">Review Recipes</h1>
        <a href="/admin" class="text-sm text-berry hover:underline">Back to Dashboard</a>
      </div>

      <!-- Status Tabs -->
      <div class="flex gap-2 mb-8">
        {statusTabs.map((s) => (
          <a
            href={`/admin/recipes?status=${s}`}
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-colors',
              s === statusFilter
                ? 'bg-berry text-white'
                : 'bg-white text-slate-600 border border-slate-200 hover:border-blush',
            ]}
          >
            {s.charAt(0).toUpperCase() + s.slice(1)}
          </a>
        ))}
      </div>

      <!-- Recipe List -->
      {recipes.length > 0 ? (
        <div class="space-y-4">
          {recipes.map((recipe) => (
            <div class="flex items-center justify-between p-5 bg-white rounded-xl shadow-sm border border-slate-100">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="font-display font-bold text-chocolate">{recipe.title}</h3>
                  <span class:list={['text-xs px-2 py-0.5 rounded-full', statusColors[recipe.status] ?? '']}>
                    {recipe.status}
                  </span>
                </div>
                <p class="text-sm text-slate-500 line-clamp-1 mb-1">{recipe.description}</p>
                <div class="text-xs text-slate-500">
                  by {recipe.author?.display_name || recipe.author?.username}
                  &middot; {new Date(recipe.created_at).toLocaleDateString()}
                  &middot; {recipe.difficulty} &middot; {recipe.base_type}
                </div>
              </div>
              <a
                href={`/admin/recipes/${recipe.id}`}
                class="ml-4 px-4 py-2 bg-berry text-white text-sm font-medium rounded-full hover:bg-berry/90 transition-colors"
              >
                Review
              </a>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white/50 rounded-2xl">
          <p class="text-slate-500">No {statusFilter} recipes.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
